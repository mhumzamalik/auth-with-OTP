# MongoDB
MONGODB_URI=mongodb://localhost:27017/authdb

# Node Environment
NODE_ENV=development

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Brevo SMTP Email Service (https://app.brevo.com/settings/keys/smtp)
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=AuthApp <noreply@yourdomain.com>

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AuthApp

# Google OAuth (for future OAuth integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
